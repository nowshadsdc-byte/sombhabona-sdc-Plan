// Sombhabona x SDC — "One Donation, Change Two Lives" platform schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Admin {
  id           String   @id @default(cuid())
  email        String   @unique @db.VarChar(191)
  name         String   @db.VarChar(191)
  passwordHash String   @db.VarChar(191)
  role         String   @default("ADMIN") @db.VarChar(191) // ADMIN | SUPER_ADMIN
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Donor {
  id           String      @id @default(cuid())
  name         String      @db.VarChar(191)
  email        String      @unique @db.VarChar(191)
  passwordHash String      @db.VarChar(191)
  phone        String?     @db.VarChar(191)
  country      String?     @db.VarChar(191)
  city         String?     @db.VarChar(191)
  avatarColor  String      @default("#0d9488") @db.VarChar(191)
  bio          String?     @db.Text
  isPublic     Boolean     @default(true)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  donations    Donation[]
}

model Child {
  id              String           @id @default(cuid())
  name            String           @db.VarChar(191)
  age             Int
  gender          String           @default("female") @db.VarChar(191)
  grade           String           @db.VarChar(191)
  school          String           @db.VarChar(191)
  location        String           @db.VarChar(191)
  background      String           @db.Text
  dream           String           @db.Text
  photoColor      String           @default("#f59e0b") @db.VarChar(191)
  status          String           @default("AVAILABLE") @db.VarChar(191) // AVAILABLE | SUPPORTED | GRADUATED
  progressPercent Int              @default(0)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  donations       Donation[]
  updates         ProgressUpdate[]
}

model Woman {
  id              String           @id @default(cuid())
  name            String           @db.VarChar(191)
  age             Int
  location        String           @db.VarChar(191)
  familyInfo      String           @db.Text
  background      String           @db.Text
  goal            String           @db.Text
  photoColor      String           @default("#ec4899") @db.VarChar(191)
  status          String           @default("AVAILABLE") @db.VarChar(191) // AVAILABLE | SUPPORTED | EMPLOYED
  progressPercent Int              @default(0)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  donations       Donation[]
  updates         ProgressUpdate[]
}

model Donation {
  id             String   @id @default(cuid())
  donorId        String   @db.VarChar(191)
  childId        String?  @db.VarChar(191)
  womanId        String?  @db.VarChar(191)
  packageId      String?  @db.VarChar(191)
  amountUSD      Float
  amountBDT      Float
  paymentMethod  String   @default("ONLINE") @db.VarChar(191) // ONLINE | OFFLINE
  paymentStatus  String   @default("PENDING") @db.VarChar(191) // PENDING | COMPLETED | FAILED
  transactionId  String?  @db.VarChar(191)
  donorMessage   String?  @db.Text
  anonymous      Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  donor  Donor  @relation(fields: [donorId], references: [id], onDelete: Cascade)
  child  Child?  @relation(fields: [childId], references: [id], onDelete: SetNull)
  woman  Woman?  @relation(fields: [womanId], references: [id], onDelete: SetNull)

  @@index([donorId])
  @@index([childId])
  @@index([womanId])
}

model ProgressUpdate {
  id         String   @id @default(cuid())
  childId    String?  @db.VarChar(191)
  womanId    String?  @db.VarChar(191)
  title      String   @db.VarChar(191)
  content    String   @db.Text
  photoColor String   @default("#14b8a6") @db.VarChar(191)
  milestone  Boolean  @default(false)
  createdAt  DateTime @default(now())

  child Child? @relation(fields: [childId], references: [id], onDelete: Cascade)
  woman Woman? @relation(fields: [womanId], references: [id], onDelete: Cascade)

  @@index([childId])
  @@index([womanId])
}

model SiteContent {
  id    String @id @default(cuid())
  key   String @unique @db.VarChar(191)
  value String @db.Text
}

model Package {
  id              String  @id @default(cuid())
  name            String  @db.VarChar(191)
  description     String  @db.Text
  priceUSD        Float
  priceBDT        Float
  childBenefit    String  @db.Text
  womanBenefit    String  @db.Text
  imageColor      String  @default("#0d9488") @db.VarChar(191)
  active          Boolean @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}
